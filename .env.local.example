# Etsy API credentials
# Get your API key at https://www.etsy.com/developers/register
ETSY_API_KEY=your_etsy_api_key_here

# Your Etsy shop ID (numeric, found in your shop manager URL)
ETSY_SHOP_ID=your_shop_id_here

# Your full Etsy shop URL (shown in footer "View all on Etsy" link)
NEXT_PUBLIC_ETSY_SHOP_URL=https://www.etsy.com/shop/YourShopName

# Base URL for internal API calls (change for production)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
